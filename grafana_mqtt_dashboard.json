        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "bfq448154nklce"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH data AS (\r\n  SELECT \r\n    timestamp,\r\n    deviceid,\r\n    metric,\r\n    value,\r\n    \r\n    CASE \r\n      WHEN ABS(value) > 20 THEN 1\r\n      ELSE 0\r\n    END AS above_threshold\r\n  FROM telemetry\r\n  WHERE deviceid = '${Equipment}' \r\n  and metric = 'MACTTORQUE_1'\r\n    AND timestamp >= NOW() - INTERVAL '1 hour'\r\n),\r\n\r\nevents AS (\r\n  SELECT *,\r\n    LAG(above_threshold) OVER (\r\n      PARTITION BY deviceid, metric\r\n      ORDER BY timestamp\r\n    ) AS prev_value\r\n  FROM data\r\n)\r\n\r\nSELECT \r\n  deviceid,\r\n  metric,\r\n  COUNT(*) AS threshold_crossings\r\nFROM events\r\nWHERE above_threshold = 1\r\n  AND COALESCE(prev_value, 0) = 0\r\nGROUP BY deviceid, metric;\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "${Equipment} Motor 1 Torque exceeds 80% of max. / last hour",
      "type": "stat"
